{
    "type": "stg_select_source",
    "group": "supply_chain",
    "topic": "supplies",
    "name": "inventory",
    "materialized": "ephemeral",
    "from": {
        "source": "development__jaffle_shop_dev_seeds.raw_supplies"
    },
    "select": [
        {
            "name": "supply_id",
            "expr": "id",
            "type": "dim",
            "description": "Unique identifier for each supply item"
        },
        {
            "name": "supply_name",
            "expr": "TRIM(name)",
            "type": "dim",
            "description": "Supply item name, trimmed"
        },
        {
            "name": "cost_cents",
            "expr": "cost",
            "type": "fct",
            "description": "Supply cost in cents"
        },
        {
            "name": "cost_dollars",
            "expr": "CAST(cost AS DECIMAL(10,2)) / 100.0",
            "type": "fct",
            "description": "Supply cost in dollars"
        },
        {
            "name": "is_perishable",
            "expr": "CASE WHEN perishable = true THEN true ELSE false END",
            "type": "dim",
            "description": "Boolean flag for perishable supplies"
        },
        {
            "name": "product_sku",
            "expr": "sku",
            "type": "dim",
            "description": "Associated product SKU"
        },
        {
            "name": "supply_category",
            "expr": "CASE WHEN LOWER(name) LIKE '%cutlery%' OR LOWER(name) LIKE '%fork%' OR LOWER(name) LIKE '%knife%' THEN 'utensils' WHEN LOWER(name) LIKE '%napkin%' OR LOWER(name) LIKE '%boat%' THEN 'packaging' WHEN perishable = true THEN 'ingredients' ELSE 'other' END",
            "type": "dim",
            "description": "Supply category classification"
        }
    ]
}