{
    "type": "mart_select_model",
    "group": "sales",
    "topic": "reporting",
    "name": "profitability",
    "tags": [
        "lightdash-explore"
    ],
    "from": {
        "model": "int__sales__orders__enriched"
    },
    "select": [
        {
            "type": "all_from_model",
            "model": "int__sales__orders__enriched",
            "include": [
                "store_id",
                "store_name",
                "order_date"
            ]
        },
        {
            "name": "order_year_month",
            "expr": "DATE_TRUNC('month', order_date)",
            "type": "dim",
            "description": "Order year-month"
        },
        {
            "name": "total_revenue_dollars",
            "expr": "SUM(order_total_dollars)",
            "type": "fct",
            "description": "Total revenue in dollars",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_aggregated_revenue",
                        "type": "sum",
                        "group_label": "Profitability Metrics",
                        "label": "Aggregated Revenue",
                        "ai_hint": "Use this for store-level or time-based revenue aggregation and profitability analysis"
                    }
                ]
            }
        },
        {
            "name": "total_tax_collected_dollars",
            "expr": "SUM(CAST(tax_paid_cents AS DECIMAL(10,2)) / 100.0)",
            "type": "fct",
            "description": "Total tax collected in dollars",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_aggregated_tax",
                        "type": "sum",
                        "group_label": "Profitability Metrics",
                        "label": "Aggregated Tax",
                        "ai_hint": "Use this for tax reporting by store location or time period"
                    }
                ]
            }
        },
        {
            "name": "order_count",
            "expr": "COUNT(*)",
            "type": "fct",
            "description": "Number of orders",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_order_volume",
                        "type": "sum",
                        "group_label": "Profitability Metrics",
                        "label": "Order Volume",
                        "ai_hint": "Use this to analyze transaction volume trends and store performance"
                    }
                ]
            }
        },
        {
            "name": "avg_order_value_dollars",
            "expr": "AVG(order_total_dollars)",
            "type": "fct",
            "description": "Average order value in dollars",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_aov_by_segment",
                        "type": "average",
                        "group_label": "Profitability Metrics",
                        "label": "AOV by Segment",
                        "ai_hint": "Use this to compare average order values across stores, time periods, or customer segments"
                    }
                ]
            }
        },
        {
            "name": "revenue_per_day",
            "expr": "SUM(order_total_dollars)",
            "type": "fct",
            "description": "Daily revenue per store",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_daily_revenue",
                        "type": "sum",
                        "group_label": "Profitability Metrics",
                        "label": "Daily Revenue",
                        "ai_hint": "Use this to analyze daily sales patterns and identify peak revenue days for staffing and inventory"
                    }
                ]
            }
        }
    ]
}