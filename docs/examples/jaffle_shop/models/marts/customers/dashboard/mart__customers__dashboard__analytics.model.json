{
    "type": "mart_select_model",
    "group": "customers",
    "topic": "dashboard",
    "name": "analytics",
    "tags": [
        "lightdash-explore"
    ],
    "from": {
        "model": "int__customers__profiles__summary"
    },
    "select": [
        {
            "type": "all_from_model",
            "model": "int__customers__profiles__summary",
            "include": [
                "customer_id",
                "customer_name",
                "customer_first_name",
                "customer_last_name",
                "has_last_name",
                "total_orders"
            ]
        },
        {
            "name": "customer_segment",
            "expr": "CASE WHEN total_orders >= 10 THEN 'VIP' WHEN total_orders >= 3 THEN 'Regular' ELSE 'New' END",
            "type": "dim",
            "description": "Customer segment classification based on order count"
        }
    ]
}