{
    "type": "stg_select_source",
    "group": "sales",
    "topic": "stores",
    "name": "locations",
    "materialized": "ephemeral",
    "from": {
        "source": "development__jaffle_shop_lightdash_dev_seeds.raw_stores"
    },
    "select": [
        {
            "name": "store_id",
            "expr": "id",
            "type": "dim",
            "description": "Unique identifier for each store"
        },
        {
            "name": "store_name",
            "expr": "TRIM(name)",
            "type": "dim",
            "description": "Store location name"
        },
        {
            "name": "store_opened_at",
            "expr": "CAST(opened_at AS TIMESTAMP)",
            "type": "dim",
            "description": "Timestamp when store opened"
        },
        {
            "name": "store_opened_date",
            "expr": "DATE(CAST(opened_at AS TIMESTAMP))",
            "type": "dim",
            "description": "Date when store opened"
        },
        {
            "name": "store_tax_rate",
            "expr": "tax_rate",
            "type": "fct",
            "description": "Local tax rate for the store"
        },
        {
            "name": "store_tax_rate_percent",
            "expr": "tax_rate * 100",
            "type": "fct",
            "description": "Tax rate as percentage"
        }
    ]
}