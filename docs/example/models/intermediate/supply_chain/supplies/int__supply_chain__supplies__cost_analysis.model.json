{
    "type": "int_join_models",
    "group": "supply_chain",
    "topic": "supplies",
    "name": "cost_analysis",
    "from": {
        "model": "stg__supply_chain__supplies__inventory",
        "join": [
            {
                "model": "stg__products__catalog__catalog",
                "type": "left",
                "on": {
                    "and": [
                        "product_sku"
                    ]
                }
            }
        ]
    },
    "select": [
        {
            "model": "stg__supply_chain__supplies__inventory",
            "type": "all_from_model"
        },
        {
            "model": "stg__products__catalog__catalog",
            "type": "all_from_model",
            "include": [
                "product_name",
                "product_type",
                "product_price_dollars"
            ]
        },
        {
            "name": "supply_to_price_ratio",
            "expr": "{{ supply_to_price_ratio() }}",
            "type": "fct",
            "description": "Supply cost as percentage of product price"
        },
        {
            "name": "cost_tier",
            "expr": "{{ cost_tier() }}",
            "type": "dim",
            "description": "Supply cost tier classification"
        }
    ]
}