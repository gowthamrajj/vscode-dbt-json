{
  "$id": "model.select.cte.schema.json",
  "title": "Schema Model Select CTE",
  "description": "Schema when selecting columns from a CTE defined in the same model",
  "anyOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["cte", "name"],
      "properties": {
        "cte": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to a CTE defined in the ctes array"
        },
        "data_type": { "$ref": "column.data_type.schema.json" },
        "description": { "$ref": "column.description.schema.json" },
        "lightdash": { "$ref": "column.lightdash.schema.json" },
        "name": { "$ref": "column.name.schema.json" },
        "data_tests": { "$ref": "column.data_tests.schema.json" },
        "type": { "const": "dim" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["cte", "name", "type"],
      "properties": {
        "cte": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to a CTE defined in the ctes array"
        },
        "data_type": { "$ref": "column.data_type.schema.json" },
        "description": { "$ref": "column.description.schema.json" },
        "lightdash": { "$ref": "column.lightdash.schema.json" },
        "name": { "$ref": "column.name.schema.json" },
        "data_tests": { "$ref": "column.data_tests.schema.json" },
        "type": { "const": "fct" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["cte", "type"],
      "properties": {
        "type": {
          "enum": ["all_from_cte", "dims_from_cte", "fcts_from_cte"]
        },
        "cte": {
          "type": "string",
          "minLength": 1,
          "description": "Reference to a CTE defined in the ctes array"
        },
        "exclude": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "column.name.schema.json" }
        },
        "include": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "column.name.schema.json" }
        }
      }
    }
  ]
}
