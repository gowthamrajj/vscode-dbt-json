{
  "$id": "model.type.int_union_models.schema.json",
  "title": "Schema Model Type Int Union Models",
  "description": "Validates schema for union models",
  "type": "object",
  "additionalProperties": false,
  "required": ["from", "group", "name", "topic", "type"],
  "properties": {
    "type": { "const": "int_union_models" },
    "group": { "$ref": "model.group.schema.json" },
    "topic": { "$ref": "model.topic.schema.json" },
    "name": { "$ref": "model.name.schema.json" },
    "description": { "$ref": "model.description.schema.json" },
    "lightdash": { "$ref": "model.lightdash.schema.json" },
    "tags": { "$ref": "model.tags.schema.json" },
    "data_tests": { "$ref": "model.data_tests.schema.json" },
    "materialization": { "$ref": "model.materialization.schema.json" },
    "materialized": { "$ref": "model.materialized.schema.json" },
    "incremental_strategy": {
      "$ref": "model.incremental_strategy.schema.json"
    },
    "sql_hooks": { "$ref": "model.sql_hooks.schema.json" },
    "partitioned_by": { "$ref": "model.partitioned_by.schema.json" },
    "exclude_daily_filter": {
      "$ref": "model.exclude_daily_filter.schema.json"
    },
    "exclude_date_filter": { "$ref": "model.exclude_date_filter.schema.json" },
    "exclude_portal_partition_columns": {
      "$ref": "model.exclude_portal_partition_columns.schema.json"
    },
    "exclude_portal_source_count": {
      "$ref": "model.exclude_portal_source_count.schema.json"
    },
    "ctes": { "$ref": "model.ctes.schema.json" },
    "select": {
      "type": "array",
      "minItems": 1,
      "items": {
        "anyOf": [
          { "$ref": "model.select.expr.schema.json" },
          { "$ref": "model.select.model.schema.json" },
          { "$ref": "model.select.cte.schema.json" }
        ]
      }
    },
    "from": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "union"],
          "properties": {
            "model": { "$ref": "model.ref.schema.json" },
            "union": {
              "type": "object",
              "additionalProperties": false,
              "required": ["models"],
              "properties": {
                "type": { "enum": ["all"] },
                "models": {
                  "type": "array",
                  "items": { "$ref": "model.ref.schema.json" }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["cte", "union"],
          "description": "CTE-based union: normalize columns via CTEs before unioning",
          "properties": {
            "cte": {
              "type": "string",
              "minLength": 1,
              "description": "First CTE in the union"
            },
            "union": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ctes"],
              "properties": {
                "type": { "enum": ["all"] },
                "ctes": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 },
                  "description": "Additional CTEs to union with"
                }
              }
            }
          }
        }
      ]
    },
    "where": { "$ref": "model.where.schema.json" }
  }
}
