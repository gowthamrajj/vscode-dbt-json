{
    "type": "int_join_models",
    "group": "customers",
    "topic": "profiles",
    "name": "summary",
    "from": {
        "model": "stg__customers__profiles__clean",
        "join": [
            {
                "model": "stg__sales__orders__standardized",
                "type": "left",
                "on": {
                    "and": [
                        "customer_id"
                    ]
                }
            }
        ]
    },
    "select": [
        {
            "type": "dims_from_model",
            "model": "stg__customers__profiles__clean"
        },
        {
            "name": "customer_segment",
            "expr": "{{ customer_segment() }}",
            "type": "dim",
            "description": "Customer segment classification based on order count",
            "exclude_from_group_by": true
        },
        {
            "name": "has_last_name",
            "expr": "stg__customers__profiles__clean.customer_last_name IS NOT NULL",
            "type": "dim",
            "description": "Whether customer provided a last name",
            "exclude_from_group_by": true
        },
        {
            "name": "total_orders",
            "expr": "COUNT(stg__sales__orders__standardized.order_id)",
            "type": "fct",
            "description": "Total number of orders placed by customer",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_total_orders_per_customer",
                        "type": "sum",
                        "group_label": "Customer Metrics",
                        "label": "Total Orders Per Customer",
                        "ai_hint": "Use this to analyze customer purchase frequency and identify high-value customers"
                    },
                    {
                        "name": "metric_avg_orders_per_customer",
                        "type": "average",
                        "group_label": "Customer Metrics",
                        "label": "Average Orders Per Customer",
                        "ai_hint": "Use this to understand typical customer engagement and repeat purchase behavior"
                    }
                ]
            }
        }
    ]
}