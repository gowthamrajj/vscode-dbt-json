{
    "type": "mart_select_model",
    "group": "sales",
    "topic": "reporting",
    "name": "revenue",
    "tags": [
        "lightdash-explore"
    ],
    "from": {
        "model": "int__sales__orders__enriched"
    },
    "select": [
        {
            "type": "all_from_model",
            "model": "int__sales__orders__enriched",
            "include": [
                "order_id",
                "customer_id",
                "customer_name",
                "store_id",
                "store_name",
                "order_date"
            ]
        },
        {
            "name": "order_year",
            "expr": "EXTRACT(YEAR FROM order_date)",
            "type": "dim",
            "description": "Order year"
        },
        {
            "name": "order_month",
            "expr": "EXTRACT(MONTH FROM order_date)",
            "type": "dim",
            "description": "Order month"
        },
        {
            "name": "order_quarter",
            "expr": "EXTRACT(QUARTER FROM order_date)",
            "type": "dim",
            "description": "Order quarter"
        },
        {
            "name": "subtotal_dollars",
            "expr": "CAST(subtotal_cents AS DECIMAL(10,2)) / 100.0",
            "type": "fct",
            "description": "Order subtotal in dollars",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_subtotal_revenue",
                        "type": "sum",
                        "group_label": "Revenue Metrics",
                        "label": "Total Subtotal Revenue",
                        "ai_hint": "Use this to analyze pre-tax revenue for reporting and comparison across tax jurisdictions"
                    }
                ]
            }
        },
        {
            "name": "tax_dollars",
            "expr": "CAST(tax_paid_cents AS DECIMAL(10,2)) / 100.0",
            "type": "fct",
            "description": "Tax amount in dollars",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_total_tax",
                        "type": "sum",
                        "group_label": "Revenue Metrics",
                        "label": "Total Tax Collected",
                        "ai_hint": "Use this for tax reporting and compliance analysis"
                    }
                ]
            }
        },
        {
            "name": "total_dollars",
            "expr": "order_total_dollars",
            "type": "fct",
            "description": "Total order amount in dollars",
            "lightdash": {
                "metrics": [
                    {
                        "name": "metric_total_revenue",
                        "type": "sum",
                        "group_label": "Revenue Metrics",
                        "label": "Total Revenue",
                        "ai_hint": "Use this as the primary revenue metric for financial reporting and dashboard KPIs"
                    },
                    {
                        "name": "metric_avg_order_value",
                        "type": "average",
                        "group_label": "Revenue Metrics",
                        "label": "Average Order Value (AOV)",
                        "ai_hint": "Use this to track AOV trends over time, a key e-commerce performance indicator"
                    }
                ]
            }
        },
        {
            "name": "revenue_tier",
            "expr": "CASE WHEN order_total_dollars >= 15.00 THEN 'High' WHEN order_total_dollars >= 8.00 THEN 'Medium' ELSE 'Low' END",
            "type": "dim",
            "description": "Revenue tier classification"
        },
        {
            "name": "is_weekend_order",
            "expr": "day_of_week(order_date) IN (6, 7)",
            "type": "dim",
            "description": "Boolean flag for weekend orders"
        }
    ]
}