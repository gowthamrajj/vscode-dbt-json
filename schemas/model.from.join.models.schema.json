{
  "$id": "model.from.join.models.schema.json",
  "title": "Schema Model From Join Models",
  "description": "Validates the join argument when joining multiple models or CTEs",
  "type": "array",
  "minItems": 1,
  "items": {
    "anyOf": [
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["model"],
        "properties": {
          "model": { "$ref": "model.ref.schema.json" },
          "override_alias": { "$ref": "column.name.schema.json" },
          "type": { "const": "cross" }
        }
      },
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["model", "on"],
        "properties": {
          "model": { "$ref": "model.ref.schema.json" },
          "override_alias": { "$ref": "column.name.schema.json" },
          "type": { "enum": ["full", "inner", "left", "right"] },
          "on": {
            "anyOf": [
              {
                "const": "dims",
                "description": "Shorthand: join on all dimension columns shared between the base and target."
              },
              {
                "type": "object",
                "description": "SQL for the join condition",
                "additionalProperties": false,
                "properties": {
                  "and": {
                    "type": "array",
                    "description": "Conditions to be combined by AND",
                    "items": {
                      "anyOf": [
                        { "$ref": "column.name.schema.json" },
                        {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["expr"],
                          "properties": {
                            "expr": {
                              "description": "SQL for the condition",
                              "type": "string"
                            }
                          }
                        },
                        {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["subquery"],
                          "properties": {
                            "subquery": { "$ref": "model.subquery.schema.json" }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            ]
          }
        }
      },
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["cte"],
        "description": "Cross join with a CTE defined in the same model",
        "properties": {
          "cte": {
            "type": "string",
            "minLength": 1,
            "description": "Name of a CTE defined in the ctes array"
          },
          "override_alias": { "$ref": "column.name.schema.json" },
          "type": { "const": "cross" }
        }
      },
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["cte", "on"],
        "description": "Conditional join with a CTE defined in the same model",
        "properties": {
          "cte": {
            "type": "string",
            "minLength": 1,
            "description": "Name of a CTE defined in the ctes array"
          },
          "override_alias": { "$ref": "column.name.schema.json" },
          "type": { "enum": ["full", "inner", "left", "right"] },
          "on": {
            "anyOf": [
              {
                "const": "dims",
                "description": "Shorthand: join on all dimension columns shared between the base and target."
              },
              {
                "type": "object",
                "description": "SQL for the join condition",
                "additionalProperties": false,
                "properties": {
                  "and": {
                    "type": "array",
                    "description": "Conditions to be combined by AND",
                    "items": {
                      "anyOf": [
                        { "$ref": "column.name.schema.json" },
                        {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["expr"],
                          "properties": {
                            "expr": {
                              "description": "SQL for the condition",
                              "type": "string"
                            }
                          }
                        },
                        {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["subquery"],
                          "properties": {
                            "subquery": { "$ref": "model.subquery.schema.json" }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            ]
          }
        }
      }
    ]
  }
}
