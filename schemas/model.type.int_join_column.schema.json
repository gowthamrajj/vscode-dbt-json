{
  "$id": "model.type.int_join_column.schema.json",
  "title": "Schema Model Type Int Join Column",
  "description": "Validates schema for int models which cross join on an unnested column",
  "type": "object",
  "additionalProperties": false,
  "required": ["from", "group", "name", "select", "topic", "type"],
  "properties": {
    "type": {
      "const": "int_join_column"
    },
    "group": {
      "$ref": "model.group.schema.json"
    },
    "topic": {
      "$ref": "model.topic.schema.json"
    },
    "name": {
      "$ref": "model.name.schema.json"
    },
    "description": {
      "$ref": "model.description.schema.json"
    },
    "lightdash": {
      "$ref": "model.lightdash.schema.json"
    },
    "tags": {
      "$ref": "model.tags.schema.json"
    },
    "data_tests": {
      "$ref": "model.data_tests.schema.json"
    },
    "materialization": {
      "$ref": "model.materialization.schema.json"
    },
    "materialized": {
      "$ref": "model.materialized.schema.json"
    },
    "incremental_strategy": {
      "$ref": "model.incremental_strategy.schema.json"
    },
    "sql_hooks": {
      "$ref": "model.sql_hooks.schema.json"
    },
    "partitioned_by": {
      "$ref": "model.partitioned_by.schema.json"
    },
    "exclude_daily_filter": {
      "$ref": "model.exclude_daily_filter.schema.json"
    },
    "exclude_date_filter": {
      "$ref": "model.exclude_date_filter.schema.json"
    },
    "exclude_portal_partition_columns": {
      "$ref": "model.exclude_portal_partition_columns.schema.json"
    },
    "exclude_portal_source_count": {
      "$ref": "model.exclude_portal_source_count.schema.json"
    },
    "group_by": {
      "$ref": "model.group_by.schema.json"
    },
    "where": {
      "$ref": "model.where.schema.json"
    },
    "select": {
      "description": "These columns will be selected in order from the unnested array column",
      "type": "array",
      "minItems": 1,
      "items": {
        "anyOf": [
          {
            "$ref": "column.name.schema.json"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "data_type": {
                "$ref": "column.data_type.schema.json"
              },
              "description": {
                "$ref": "column.description.schema.json"
              },
              "expr": {
                "$ref": "column.expr.schema.json"
              },
              "lightdash": {
                "$ref": "column.lightdash.schema.json"
              },
              "name": {
                "$ref": "column.name.schema.json"
              },
              "type": {
                "enum": ["dim", "fct"]
              }
            }
          }
        ]
      }
    },
    "from": {
      "type": "object",
      "additionalProperties": false,
      "required": ["join", "model"],
      "properties": {
        "model": {
          "$ref": "model.ref.schema.json"
        },
        "join": {
          "$ref": "model.from.join.column.schema.json"
        }
      }
    }
  }
}
