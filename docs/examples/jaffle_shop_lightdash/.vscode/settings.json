{
    "dbt.enableNewLineagePanel": true,
    "dbt.installDepsOnProjectInitialization": false,
    "dj.airflowGenerateDags": false,
    "dj.pythonVenvPath": ".venv",
    "json.schemas": [
        {
            "fileMatch": [
                "*.model.json"
            ],
            "url": ".dj/schemas/model.schema.json"
        },
        {
            "fileMatch": [
                "*.source.json"
            ],
            "url": ".dj/schemas/source.schema.json"
        }
    ],
}