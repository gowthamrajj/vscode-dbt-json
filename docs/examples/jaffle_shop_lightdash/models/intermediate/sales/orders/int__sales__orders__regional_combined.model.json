{
    "type": "int_union_models",
    "group": "sales",
    "topic": "orders",
    "name": "regional_combined",
    "tags": [
        "lightdash-explore"
    ],
    "from": {
        "model": "int__sales__orders__enriched",
        "union": {
            "type": "all",
            "models": [
                "int__sales__orders__enriched"
            ]
        }
    },
    "select": [
        {
            "type": "all_from_model",
            "model": "int__sales__orders__enriched"
        },
        {
            "name": "region",
            "expr": "CASE WHEN store_name IN ('Philadelphia', 'Brooklyn') THEN 'East Coast' WHEN store_name IN ('San Francisco', 'Los Angeles') THEN 'West Coast' ELSE 'Other' END",
            "type": "dim",
            "description": "Geographic region classification",
            "lightdash": {
                "dimension": {
                    "type": "string"
                }
            }
        }
    ],
    "description": "Unified orders data with geographic region classification for regional analysis"
}